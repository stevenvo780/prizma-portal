# Portal — Vite environment variables for production deployments.
# In Vercel: set these under Project Settings > Environment Variables.
# Locally: copy to .env and fill with real values (do NOT commit secrets).

# Per-service URLs — override localhost defaults for production/staging.
# El código lee el prefijo NUEVO (Prizma) y cae al VIEJO como fallback (shim R2).
VITE_HERMES_URL=https://hermes.tu-dominio.com
VITE_IRIS_URL=https://iris.tu-dominio.com
VITE_TALARIA_URL=https://talaria.tu-dominio.com
VITE_TALANTON_URL=https://talanton.tu-dominio.com
VITE_PISTIS_URL=https://pistis.tu-dominio.com
VITE_LOGOS_URL=https://logos.tu-dominio.com
VITE_MNEMOSYNE_URL=https://mnemosyne.tu-dominio.com
VITE_PEITHO_URL=https://peitho.tu-dominio.com
VITE_TALOS_URL=https://talos.tu-dominio.com
VITE_NOUS_URL=https://nous.tu-dominio.com

